# Copy to .env.local and fill in values

# Python AI backend (Next.js API routes proxy to this)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# WebSocket server URL for real-time agent thought stream (socket.io)
NEXT_PUBLIC_WS_URL=http://localhost:8000

# ML inference server — only used server-side via proxyToBackend()
ML_SERVER_URL=http://localhost:8001
